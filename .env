# Security
SECRET_KEY=your-super-secret-key-here
JWT_SECRET=your-jwt-secret-key-here
API_KEYS=grafana-key-123,admin-key-456,monitoring-key-789

# Basic Authentication Users (username:password)
BASIC_AUTH_USERS=grafana:grafana123,admin:admin123,viewer:viewer123

# SSL Certificates
SSL_CERT=cert.pem
SSL_KEY=key.pem

# CORS
ALLOWED_ORIGINS=https://grafana.example.com,http://localhost:3000

# Debug
DEBUG=False